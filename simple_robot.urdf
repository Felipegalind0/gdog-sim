<?xml version="1.0"?>
<robot name="simple_quadruped_robot">
  <!-- Body (Big Rectangle) -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.25 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.25 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- Macro-like definitions expanded for 4 legs: FL, FR, RL, RR -->
  
  <!-- FRONT LEFT -->
  <link name="fl_thigh">
    <visual>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="green"><color rgba="0.2 0.8 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="1.0"/><origin xyz="0 0 -0.1"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <link name="fl_calf">
    <visual>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="orange"><color rgba="0.8 0.5 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.5"/><origin xyz="0 0 -0.1"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <!-- FRONT RIGHT -->
  <link name="fr_thigh">
    <visual>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="green"/>
    </visual>
    <collision>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="1.0"/><origin xyz="0 0 -0.1"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <link name="fr_calf">
    <visual>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.5"/><origin xyz="0 0 -0.1"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <!-- REAR LEFT -->
  <link name="rl_thigh">
    <visual>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="green"/>
    </visual>
    <collision>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="1.0"/><origin xyz="0 0 -0.1"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <link name="rl_calf">
    <visual>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.5"/><origin xyz="0 0 -0.1"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <!-- REAR RIGHT -->
  <link name="rr_thigh">
    <visual>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="green"/>
    </visual>
    <collision>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="1.0"/><origin xyz="0 0 -0.1"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <link name="rr_calf">
    <visual>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.5"/><origin xyz="0 0 -0.1"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <!-- JOINTS -->
  <!-- Hip Joints (Connecting body to thigh) -->
  <joint name="fl_hip" type="revolute">
    <parent link="base_link"/>
    <child link="fl_thigh"/>
    <origin xyz="0.15 0.15 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="100" velocity="5"/>
  </joint>
  <joint name="fr_hip" type="revolute">
    <parent link="base_link"/>
    <child link="fr_thigh"/>
    <origin xyz="0.15 -0.15 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="100" velocity="5"/>
  </joint>
  <joint name="rl_hip" type="revolute">
    <parent link="base_link"/>
    <child link="rl_thigh"/>
    <origin xyz="-0.15 0.15 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="100" velocity="5"/>
  </joint>
  <joint name="rr_hip" type="revolute">
    <parent link="base_link"/>
    <child link="rr_thigh"/>
    <origin xyz="-0.15 -0.15 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="100" velocity="5"/>
  </joint>

  <!-- Knee Joints (Connecting thigh to calf) -->
  <joint name="fl_knee" type="revolute">
    <parent link="fl_thigh"/>
    <child link="fl_calf"/>
    <origin xyz="0 0 -0.2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="0" effort="100" velocity="5"/>
  </joint>
  <joint name="fr_knee" type="revolute">
    <parent link="fr_thigh"/>
    <child link="fr_calf"/>
    <origin xyz="0 0 -0.2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="0" effort="100" velocity="5"/>
  </joint>
  <joint name="rl_knee" type="revolute">
    <parent link="rl_thigh"/>
    <child link="rl_calf"/>
    <origin xyz="0 0 -0.2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="0" effort="100" velocity="5"/>
  </joint>
  <joint name="rr_knee" type="revolute">
    <parent link="rr_thigh"/>
    <child link="rr_calf"/>
    <origin xyz="0 0 -0.2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="0" effort="100" velocity="5"/>
  </joint>

</robot>
